{
  "manifest_version": 3,
  "name": "Telify - Phone Number Links",
  "version": "1.0",
  "description": "Automatically converts phone numbers into clickable tel: links on any webpage",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Telify - Phone Number Links"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}